<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 140" width="160" height="140">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#0ea5e9"/>
      <stop offset="100%" stop-color="#14b8a6"/>
    </linearGradient>
    <linearGradient id="grad2" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#0ea5e9"/>
      <stop offset="33%" stop-color="#14b8a6"/>
      <stop offset="66%" stop-color="#8b5cf6"/>
      <stop offset="100%" stop-color="#8b5cf6"/>
    </linearGradient>
    <linearGradient id="grad3" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#0ea5e9"/>
      <stop offset="25%" stop-color="#14b8a6"/>
      <stop offset="50%" stop-color="#8b5cf6"/>
      <stop offset="75%" stop-color="#f97316"/>
      <stop offset="100%" stop-color="#f97316"/>
    </linearGradient>
    <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="2.5" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <style>
    .node { stroke:#0f172a; stroke-width:2.5; r:6; }
    .input { fill:#0ea5e9; }
    .hidden1 { fill:#14b8a6; }
    .hidden2 { fill:#8b5cf6; }
    .output { fill:#f97316; }
    .signal { stroke-width:1.2; fill:none; stroke-linecap:round; filter:url(#glow); stroke-dasharray:2 4; animation: flow 1.5s linear infinite;}
    @keyframes flow { 0%{stroke-dashoffset:0;} 100%{stroke-dashoffset:-6;} }
  </style>

  <!-- Nodes -->
  <!-- Input -->
  <circle class="node input" cx="20" cy="30"/>
  <circle class="node input" cx="20" cy="70"/>
  <circle class="node input" cx="20" cy="110"/>

  <!-- Hidden Layer 1 -->
  <circle class="node hidden1" cx="60" cy="20"/>
  <circle class="node hidden1" cx="60" cy="50"/>
  <circle class="node hidden1" cx="60" cy="80"/>
  <circle class="node hidden1" cx="60" cy="110"/>

  <!-- Hidden Layer 2 -->
  <circle class="node hidden2" cx="100" cy="20"/>
  <circle class="node hidden2" cx="100" cy="50"/>
  <circle class="node hidden2" cx="100" cy="80"/>
  <circle class="node hidden2" cx="100" cy="110"/>

  <!-- Output -->
  <circle class="node output" cx="140" cy="50"/>
  <circle class="node output" cx="140" cy="90"/>

  <!-- Connections: Input -> Hidden1 -->
  <path class="signal" stroke="url(#grad1)" d="M20 30 L60 20"/>
  <path class="signal" stroke="url(#grad1)" d="M20 30 L60 50"/>
  <path class="signal" stroke="url(#grad1)" d="M20 30 L60 80"/>
  <path class="signal" stroke="url(#grad1)" d="M20 30 L60 110"/>

  <path class="signal" stroke="url(#grad1)" d="M20 70 L60 20"/>
  <path class="signal" stroke="url(#grad1)" d="M20 70 L60 50"/>
  <path class="signal" stroke="url(#grad1)" d="M20 70 L60 80"/>
  <path class="signal" stroke="url(#grad1)" d="M20 70 L60 110"/>

  <path class="signal" stroke="url(#grad1)" d="M20 110 L60 20"/>
  <path class="signal" stroke="url(#grad1)" d="M20 110 L60 50"/>
  <path class="signal" stroke="url(#grad1)" d="M20 110 L60 80"/>
  <path class="signal" stroke="url(#grad1)" d="M20 110 L60 110"/>

  <!-- Connections: Hidden1 -> Hidden2 -->
  <path class="signal" stroke="url(#grad2)" d="M60 20 L100 20"/>
  <path class="signal" stroke="url(#grad2)" d="M60 20 L100 50"/>
  <path class="signal" stroke="url(#grad2)" d="M60 20 L100 80"/>
  <path class="signal" stroke="url(#grad2)" d="M60 20 L100 110"/>

  <path class="signal" stroke="url(#grad2)" d="M60 50 L100 20"/>
  <path class="signal" stroke="url(#grad2)" d="M60 50 L100 50"/>
  <path class="signal" stroke="url(#grad2)" d="M60 50 L100 80"/>
  <path class="signal" stroke="url(#grad2)" d="M60 50 L100 110"/>

  <path class="signal" stroke="url(#grad2)" d="M60 80 L100 20"/>
  <path class="signal" stroke="url(#grad2)" d="M60 80 L100 50"/>
  <path class="signal" stroke="url(#grad2)" d="M60 80 L100 80"/>
  <path class="signal" stroke="url(#grad2)" d="M60 80 L100 110"/>

  <path class="signal" stroke="url(#grad2)" d="M60 110 L100 20"/>
  <path class="signal" stroke="url(#grad2)" d="M60 110 L100 50"/>
  <path class="signal" stroke="url(#grad2)" d="M60 110 L100 80"/>
  <path class="signal" stroke="url(#grad2)" d="M60 110 L100 110"/>

  <!-- Connections: Hidden2 -> Output -->
  <path class="signal" stroke="url(#grad3)" d="M100 20 L140 50"/>
  <path class="signal" stroke="url(#grad3)" d="M100 20 L140 90"/>
  <path class="signal" stroke="url(#grad3)" d="M100 50 L140 50"/>
  <path class="signal" stroke="url(#grad3)" d="M100 50 L140 90"/>
  <path class="signal" stroke="url(#grad3)" d="M100 80 L140 50"/>
  <path class="signal" stroke="url(#grad3)" d="M100 80 L140 90"/>
  <path class="signal" stroke="url(#grad3)" d="M100 110 L140 50"/>
  <path class="signal" stroke="url(#grad3)" d="M100 110 L140 90"/>
</svg>
